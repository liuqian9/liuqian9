# CLIBOT 环境变量
# 部署时在 Render 或其他平台上配置这些环境变量

# 飞书应用 App ID
FEISHU_APP_ID=cli_aa93379b9d399cb5

# 飞书应用 App Secret (从飞书开发者后台获取)
FEISHU_APP_SECRET=你的AppSecret

# 飞书事件订阅 Verification Token (从飞书开发者后台 -> 事件订阅 获取)
FEISHU_VERIFICATION_TOKEN=你的VerificationToken

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-d0f23fd30a6741aa8d0b46d06e4e391b

# 端口
PORT=3000
